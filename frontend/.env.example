# =============================================================================
# Chat Shield — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# ── Hugging Face Inference API key ───────────────────────────────────────────
# Required for the AI semantic detection layer (facebook/bart-large-mnli).
# Without this key, the app still works — it falls back to the local rule engine.
#
# Get a free key at: https://huggingface.co/settings/tokens
# The free tier allows ~30,000 characters/month with rate limits.
# Use a READ-scoped token (not write).
#
VITE_HF_API_KEY=hf_YOUR_API_KEY_HERE

# ── Notes ────────────────────────────────────────────────────────────────────
# • Vite only exposes variables prefixed with VITE_ to client-side code.
# • Access in code via: import.meta.env.VITE_HF_API_KEY
# • The key is embedded in the built JS bundle — do not use a key with
#   write permissions or billing attached. Read-only inference keys are safe.
